generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contas {
  idconta           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  idusuario         String      @db.Uuid
  iddependente      String?     @db.Uuid
  valor             Decimal     @db.Decimal(12, 2)
  tipo              String      @db.VarChar(20)
  categoria         String      @db.VarChar(75)
  status            String      @db.VarChar(20)
  quantidadeparcela Int         @default(1)
  datavencimento    DateTime    @db.Date
  datacriacao       DateTime?   @default(now()) @db.Timestamptz(6)
  dependente        dependente? @relation(fields: [iddependente], references: [iddependente], onUpdate: NoAction)
  usuario           usuario     @relation(fields: [idusuario], references: [idusuario], onDelete: Cascade, onUpdate: NoAction)
}

model dependente {
  iddependente String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  idusuario    String   @db.Uuid
  nome         String   @db.VarChar(255)
  cpf          String   @unique @db.VarChar(11)
  parentesco   String   @db.VarChar(255)
  contas       contas[]
  usuario      usuario  @relation(fields: [idusuario], references: [idusuario], onDelete: Cascade, onUpdate: NoAction)
}

model usuario {
  idusuario   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cpf         String       @unique @db.VarChar(11)
  nome        String       @db.VarChar(255)
  email       String       @unique @db.VarChar(255)
  senha       String       @db.VarChar(400)
  datacriacao DateTime?    @default(now()) @db.Timestamptz(6)
  contas      contas[]
  dependente  dependente[]
}
